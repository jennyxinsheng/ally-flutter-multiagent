      "defiance_noncompliance": {
        "id": "defiance",
        "title": "Defiance and Non-Compliance",
        "description": {
          "definition": "Refusal (active or passive) to follow directions or comply with requests from adults",
          "types": {
            "non_compliance": "Not performing requested behavior (passive or active)",
            "defiance": "Overt, sometimes hostile resistance to authority"
          },
          "common_manifestations": [
            "saying 'no' repeatedly",
            "ignoring instructions",
            "doing opposite of what's asked",
            "arguing with adults",
            "deliberate rule-breaking"
          ]
        },
        "neurobiological_factors": {
          "brain_development": [
            "Emerging autonomy drive",
            "Prefrontal cortex immaturity",
            "Difficulty with impulse control",
            "Limited emotional regulation"
          ]
        },
        "immediate_strategies": {
          "effective_approaches": [
            "Offer limited choices",
            "Use when/then statements",
            "Stay calm and neutral",
            "Follow through consistently"
          ],
          "scripts": {
            "choice_giving": "Would you like to put on shoes first or jacket first?",
            "when_then": "When you clean up toys, then we can read a story",
            "validation": "You really don't want to clean up right now. It's still time to do it."
          }
        }
      },
      "feeding_difficulties": {
        "id": "feeding",
        "title": "Feeding Difficulties",
        "description": {
          "definition": "Challenges with eating, including picky eating, food refusal, mealtime tantrums",
          "common_issues": [
            "extreme food selectivity",
            "refusing entire food groups",
            "mealtime meltdowns",
            "texture aversions",
            "neophobia (fear of new foods)"
          ]
        },
        "age_specific_patterns": {
          "1-2_years": {
            "typical_behaviors": ["food throwing", "sudden preferences", "texture exploration"],
            "developmental_factors": ["autonomy assertion", "sensory development"]
          },
          "3-5_years": {
            "typical_behaviors": ["rigid food preferences", "negotiating meals", "social eating challenges"],
            "developmental_factors": ["control seeking", "routine preference"]
          }
        },
        "neurobiological_factors": {
          "sensory_processing": "Heightened sensitivity to taste, texture, smell",
          "anxiety_response": "Amygdala activation with new foods",
          "reward_system": "Preference for familiar foods (dopamine response)"
        },
        "strategies": {
          "immediate": {
            "dos": [
              "Stay neutral during meals",
              "Offer preferred foods alongside new ones",
              "Make meals social and pleasant",
              "Respect child's appetite"
            ],
            "donts": [
              "Force feeding",
              "Use dessert as reward",
              "Show frustration",
              "Make separate meals"
            ]
          },
          "preventative": {
            "exposure_strategies": [
              "Food play outside meals",
              "Cooking together",
              "Garden to table activities",
              "Reading books about food"
            ],
            "mealtime_structure": [
              "Regular meal/snack times",
              "Family style serving",
              "No grazing between meals",
              "Consistent mealtime rules"
            ]
          }
        },
        "professional_support": {
          "orange_flags": [
            "Weight loss or poor growth",
            "Eating fewer than 20 foods",
            "Anxiety around meals",
            "Gagging/vomiting with foods"
          ],
          "specialists": [
            "Pediatric dietitian",
            "Occupational therapist (feeding specialist)",
            "Speech therapist (oral motor)",
            "Pediatric gastroenterologist"
          ]
        }
      },
      "tantrums_emotional_outbursts": {
        "id": "tantrums",
        "title": "Tantrum/Emotional Outburst Behavior",
        "description": {
          "definition": "Sudden, intense display of frustration, anger, or distress",
          "peak_ages": "1-3 years",
          "common_triggers": [
            "transitions",
            "denied requests",
            "frustration",
            "overstimulation",
            "hunger/tiredness"
          ]
        },
        "neurobiological_understanding": {
          "brain_state": "Amygdala hijack - prefrontal cortex offline",
          "stress_response": "Fight/flight/freeze activation",
          "developmental_factors": "Limited emotional regulation capacity"
        },
        "immediate_response": {
          "parent_steps": [
            "Ensure safety",
            "Stay calm and present",
            "Minimize talking",
            "Wait for storm to pass",
            "Reconnect when calm"
          ],
          "what_not_to_do": [
            "Reason during tantrum",
            "Give in to demands",
            "Punish emotional expression",
            "Leave child alone (under 3)"
          ]
        },
        "prevention": {
          "strategies": [
            "Predictable routines",
            "Adequate sleep/food",
            "Teaching emotion words",
            "Practicing calm-down strategies",
            "Identifying triggers"
          ]
        }
      },
