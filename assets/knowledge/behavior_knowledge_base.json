    "behavioral_categories": {
      "aggressive_behavior": {
        "id": "aggression",
        "title": "Aggressive Behaviour",
        "description": {
          "definition": "Actions where a child reacts in a hostile or harmful way toward others (parents, peers, siblings, adults, animals)",
          "common_manifestations": [
            "hitting",
            "biting",
            "kicking",
            "pushing",
            "throwing objects at others",
            "verbal aggression"
          ]
        },
        "age_specific_behaviors": {
          "1-2_years": {
            "behaviors": ["biting", "hitting", "hair pulling"],
            "frequency": "common",
            "typical_triggers": ["frustration", "communication difficulties", "sensory exploration"]
          },
          "3-4_years": {
            "behaviors": ["hitting when toys are taken", "pushing peers", "throwing objects"],
            "frequency": "common but decreasing",
            "typical_triggers": ["sharing conflicts", "frustration", "attention-seeking"]
          },
          "4-5_years": {
            "behaviors": ["verbal aggression", "planned retaliation", "bullying behaviors"],
            "frequency": "less common",
            "typical_triggers": ["social conflicts", "competition", "emotional dysregulation"]
          }
        },
        "neurobiological_factors": {
          "brain_regions_involved": [
            "amygdala (emotional reactivity)",
            "prefrontal_cortex (impulse control - underdeveloped)",
            "anterior_cingulate_cortex (conflict monitoring)",
            "mirror_neuron_system (social learning)"
          ],
          "developmental_considerations": [
            "Limited prefrontal cortex development",
            "High amygdala reactivity",
            "Developing language skills",
            "Emerging theory of mind"
          ]
        },
        "immediate_strategies": {
          "parent_regulation": {
            "steps": [
              "Stay calm and regulate own emotions",
              "Ensure immediate safety",
              "Use neutral, firm voice",
              "Remove child from situation if needed"
            ],
            "scripts": {
              "initial_response": "Hands are not for hitting. We use gentle touches.",
              "emotion_validation": "I see you're very frustrated. It's okay to feel mad.",
              "boundary_setting": "I can't let you hurt others. Let's find a safe way to show your feelings."
            }
          },
          "child_support": {
            "calming_techniques": [
              "Deep breathing together",
              "Counting to 10",
              "Squeezing hands or stress ball",
              "Safe physical outlet (stomping feet)"
            ]
          }
        },
        "preventative_strategies": {
          "skill_building": {
            "emotion_identification": {
              "activities": [
                "Emotion naming practice",
                "Feeling faces chart",
                "Body sensation awareness"
              ],
              "scripts": [
                "When your face gets hot, that might be anger",
                "Let's name that feeling together"
              ]
            },
            "alternative_behaviors": {
              "replacement_skills": [
                "Using words: 'I'm mad!'",
                "Asking for help",
                "Taking space",
                "Deep breathing"
              ],
              "practice_opportunities": [
                "Role-play with dolls",
                "Social stories",
                "Calm moment rehearsal"
              ]
            }
          },
          "environmental_modifications": [
            "Reduce overstimulation",
            "Ensure adequate sleep/nutrition",
            "Minimize triggers",
            "Increase supervision during high-risk times"
          ]
        },
        "developmental_norms": {
          "normal_range": {
            "age": "1-3 years",
            "frequency": "Several times per week",
            "context": "During frustration, transitions, or conflicts"
          },
          "orange_flags": {
            "indicators": [
              "Aggression increasing after age 4",
              "Targeting specific individuals repeatedly",
              "Lack of remorse",
              "Aggression without clear triggers"
            ],
            "frequency": "Daily aggressive incidents",
            "duration": "Persisting beyond 6 months of intervention"
          },
          "red_flags": {
            "immediate_concerns": [
              "Serious injury to others",
              "Use of weapons or objects to harm",
              "Aggression toward animals",
              "Premeditated violence"
